<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VehiculosMaui.Views.InicioPage"
             Title="Panel Principal"
             BackgroundColor="#F0F2F5">

	<ScrollView VerticalOptions="Center">
		<VerticalStackLayout Padding="25" Spacing="30">

			<VerticalStackLayout Spacing="5" HorizontalOptions="Center">
				<Label Text="Bienvenido de nuevo"
                       TextColor="#555555"
                       FontSize="16"
                       HorizontalOptions="Center"/>
				<Label Text="Gestión de Flota"
                       TextColor="#2196F3"
                       FontSize="28"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>
			</VerticalStackLayout>

			<Grid ColumnDefinitions="*, *"
                  RowDefinitions="Auto, Auto"
                  ColumnSpacing="20"
                  RowSpacing="20">

				<Button Grid.Row="0" Grid.Column="0"
                        Text="Vehículos"
                        HeightRequest="140"
                        BackgroundColor="White"
                        TextColor="#2196F3"
                        FontSize="16"
                        FontAttributes="Bold"
                        CornerRadius="15"
                        BorderColor="#E0E0E0"
                        BorderWidth="1">
					<Button.Shadow>
						<Shadow Brush="Black" Offset="0,2" Opacity="0.05" Radius="5"/>
					</Button.Shadow>
				</Button>

				<Button Grid.Row="0" Grid.Column="1"
                        Text="Mantenimientos"
                        HeightRequest="140"
                        BackgroundColor="White"
                        TextColor="#2196F3"
                        FontSize="15"
                        FontAttributes="Bold"
                        CornerRadius="15"
                        BorderColor="#E0E0E0"
                        BorderWidth="1">
					<Button.Shadow>
						<Shadow Brush="Black" Offset="0,2" Opacity="0.05" Radius="5"/>
					</Button.Shadow>
				</Button>

				<Button Grid.Row="1" Grid.Column="0"
                        Text="Reportes Fallas"
                        HeightRequest="140"
                        BackgroundColor="White"
                        TextColor="#F44336"
                        FontSize="15"
                        FontAttributes="Bold"
                        CornerRadius="15"
                        BorderColor="#E0E0E0"
                        BorderWidth="1">
					<Button.Shadow>
						<Shadow Brush="Black" Offset="0,2" Opacity="0.05" Radius="5"/>
					</Button.Shadow>
				</Button>

				<Button Grid.Row="1" Grid.Column="1"
                        Text="Catálogos"
                        HeightRequest="140"
                        BackgroundColor="#2196F3"
                        TextColor="White"
                        FontSize="16"
                        FontAttributes="Bold"
                        CornerRadius="15">
					<Button.Shadow>
						<Shadow Brush="#2196F3" Offset="0,4" Opacity="0.2" Radius="8"/>
					</Button.Shadow>
				</Button>

			</Grid>

			<Label Text="v1.0.2"
                   TextColor="#BBBBBB"
                   FontSize="12"
                   HorizontalOptions="Center"
                   Margin="0,20,0,0"/>

		</VerticalStackLayout>
	</ScrollView>

</ContentPage>