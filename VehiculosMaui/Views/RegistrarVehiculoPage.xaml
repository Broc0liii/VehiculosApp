<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VehiculosMaui.Views.RegistrarVehiculoPage"
             Title="Nuevo Vehículo"
             BackgroundColor="#F5F6FA">

    <ScrollView>
        <VerticalStackLayout Padding="25" Spacing="20">
            
            <VerticalStackLayout Spacing="5" Margin="0,10">
                <Label Text="Alta de Unidad" FontSize="22" FontAttributes="Bold" TextColor="#212121" />
                <Label Text="Ingrese los datos de identificación del vehículo." FontSize="14" TextColor="#757575" />
            </VerticalStackLayout>

            <Border StrokeShape="RoundRectangle 15" StrokeThickness="0" BackgroundColor="White" Padding="20">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Opacity="0.05" Radius="10"/>
                </Border.Shadow>

                <VerticalStackLayout Spacing="18">

                    <VerticalStackLayout Spacing="5">
                        <Label Text="PLACA / MATRÍCULA" FontSize="11" FontAttributes="Bold" TextColor="#2196F3" CharacterSpacing="1"/>
                        <Entry Placeholder="Ej: ABC-1234" TextTransform="Uppercase" MaxLength="10" />
                        <BoxView HeightRequest="1" Color="#EEEEEE" />
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                        <VerticalStackLayout Grid.Column="0" Spacing="5">
                            <Label Text="MARCA" FontSize="11" FontAttributes="Bold" TextColor="#2196F3" />
                            <Entry Placeholder="Nissan" />
                            <BoxView HeightRequest="1" Color="#EEEEEE" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="5">
                            <Label Text="MODELO" FontSize="11" FontAttributes="Bold" TextColor="#2196F3" />
                            <Entry Placeholder="Sentra" />
                            <BoxView HeightRequest="1" Color="#EEEEEE" />
                        </VerticalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                        <VerticalStackLayout Grid.Column="0" Spacing="5">
                            <Label Text="AÑO" FontSize="11" FontAttributes="Bold" TextColor="#2196F3" />
                            <Entry Placeholder="2024" Keyboard="Numeric" MaxLength="4" />
                            <BoxView HeightRequest="1" Color="#EEEEEE" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="5">
                            <Label Text="TIPO" FontSize="11" FontAttributes="Bold" TextColor="#2196F3" />
                            <Picker Title="Seleccionar...">
                                <Picker.ItemsSource>
                                    <x:Array Type="{x:Type x:String}">
                                        <x:String>Sedán</x:String>
                                        <x:String>SUV</x:String>
                                        <x:String>Pick-up</x:String>
                                        <x:String>Carga</x:String>
                                    </x:Array>
                                </Picker.ItemsSource>
                            </Picker>
                            <BoxView HeightRequest="1" Color="#EEEEEE" />
                        </VerticalStackLayout>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Spacing="12" Margin="0,10,0,30">
                <Button Text="Registrar Vehículo" 
                        HeightRequest="60"
                        BackgroundColor="#2196F3"
                        TextColor="White"
                        FontSize="16"
                        FontAttributes="Bold"
                        CornerRadius="12">
                    <Button.Shadow>
                        <Shadow Brush="#2196F3" Offset="0,4" Opacity="0.3" Radius="8"/>
                    </Button.Shadow>
                </Button>

                <Button Text="Cancelar" 
                        HeightRequest="50"
                        BackgroundColor="Transparent"
                        TextColor="#F44336"
                        FontSize="14"
                        FontAttributes="Bold"
                        CornerRadius="12"
                        BorderColor="#F44336"
                        BorderWidth="1" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>