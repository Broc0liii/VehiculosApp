<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VehiculosMaui.Views.CatalogosPage"
             Title="Gestión de Catálogos"
             BackgroundColor="#F5F5F5">
	<ScrollView>
		<VerticalStackLayout Padding="25" Spacing="20" VerticalOptions="Start">

			<Label Text="Seleccione una categoría para administrar:"
                   FontSize="16"
                   TextColor="#666666"
                   Margin="0,10,0,10"
                   HorizontalOptions="Center"/>

			<Button Text="Tipos de Vehículo"
                    HeightRequest="70"
                    FontSize="18"
                    CornerRadius="12"
                    TextColor="White"
                    FontAttributes="Bold"
                    CharacterSpacing="1">
				<Button.Background>
					<LinearGradientBrush EndPoint="1,0">
						<GradientStop Color="#1976D2" Offset="0.1" />
						<GradientStop Color="#2196F3" Offset="1.0" />
					</LinearGradientBrush>
				</Button.Background>
				<Button.Shadow>
					<Shadow Brush="Black" Offset="0,4" Radius="5" Opacity="0.1" />
				</Button.Shadow>
			</Button>

			<Button Text="Tipos de Servicio"
                    HeightRequest="70"
                    FontSize="18"
                    CornerRadius="12"
                    TextColor="White"
                    FontAttributes="Bold"
                    CharacterSpacing="1">
				<Button.Background>
					<LinearGradientBrush EndPoint="1,0">
						<GradientStop Color="#1976D2" Offset="0.1" />
						<GradientStop Color="#2196F3" Offset="1.0" />
					</LinearGradientBrush>
				</Button.Background>
				<Button.Shadow>
					<Shadow Brush="Black" Offset="0,4" Radius="5" Opacity="0.1" />
				</Button.Shadow>
			</Button>

			<Button Text="Estados del Vehículo"
                    HeightRequest="70"
                    FontSize="18"
                    CornerRadius="12"
                    TextColor="White"
                    FontAttributes="Bold"
                    CharacterSpacing="1">
				<Button.Background>
					<LinearGradientBrush EndPoint="1,0">
						<GradientStop Color="#1976D2" Offset="0.1" />
						<GradientStop Color="#2196F3" Offset="1.0" />
					</LinearGradientBrush>
				</Button.Background>
				<Button.Shadow>
					<Shadow Brush="Black" Offset="0,4" Radius="5" Opacity="0.1" />
				</Button.Shadow>
			</Button>

		</VerticalStackLayout>
	</ScrollView>
</ContentPage>