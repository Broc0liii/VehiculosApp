<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VehiculosMaui.Views.ReporteFallaPage"
             Title="Reportar Problema"
             BackgroundColor="#FDFDFD">

	<ScrollView>
		<VerticalStackLayout Padding="25" Spacing="25">

			<Border StrokeShape="RoundRectangle 10"
                    BackgroundColor="#FFF4F4"
                    Stroke="#FFCDD2"
                    Padding="15">
				<HorizontalStackLayout Spacing="10" VerticalOptions="Center">
					<Label Text="⚠" FontSize="20" TextColor="#D32F2F" VerticalOptions="Center" />
					<Label Text="Complete la información para generar el reporte de falla."
                           TextColor="#B71C1C"
                           FontSize="13"
                           VerticalOptions="Center" />
				</HorizontalStackLayout>
			</Border>

			<Border StrokeShape="RoundRectangle 15"
                    StrokeThickness="0"
                    BackgroundColor="White"
                    Padding="20">
				<Border.Shadow>
					<Shadow Brush="Black" Offset="0,2" Opacity="0.05" Radius="10"/>
				</Border.Shadow>

				<VerticalStackLayout Spacing="20">

					<VerticalStackLayout Spacing="5">
						<Label Text="FECHA DEL INCIDENTE" FontSize="11" FontAttributes="Bold" TextColor="#757575" CharacterSpacing="1"/>
						<DatePicker Format="dd/MM/yyyy" TextColor="#333333" />
						<BoxView HeightRequest="1" Color="#EEEEEE" />
					</VerticalStackLayout>

					<VerticalStackLayout Spacing="8">
						<Label Text="DESCRIPCIÓN DEL PROBLEMA" FontSize="11" FontAttributes="Bold" TextColor="#757575" CharacterSpacing="1"/>

						<Border StrokeShape="RoundRectangle 8"
                                Stroke="#E0E0E0"
                                StrokeThickness="1"
                                BackgroundColor="#FAFAFA"
                                Padding="5">
							<Editor Placeholder="¿Qué falló? Ej: Ruidos en la suspensión delantera al girar..."
                                    HeightRequest="180"
                                    AutoSize="Disabled"
                                    TextColor="#333333"
                                    FontSize="15"
                                    Margin="5"/>
						</Border>
					</VerticalStackLayout>

				</VerticalStackLayout>
			</Border>

			<Button Text="Enviar Reporte"
                    HeightRequest="60"
                    BackgroundColor="#D32F2F"
                    TextColor="White"
                    FontSize="18"
                    FontAttributes="Bold"
                    CornerRadius="12">
				<Button.Shadow>
					<Shadow Brush="#D32F2F" Offset="0,4" Opacity="0.3" Radius="8"/>
				</Button.Shadow>
			</Button>

			<Button Text="Descartar"
                    BackgroundColor="Transparent"
                    TextColor="#757575"
                    FontSize="14"
                    HorizontalOptions="Center" />

		</VerticalStackLayout>
	</ScrollView>
</ContentPage>