<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VehiculosMaui.Views.ReporteServiciosPage"
             Title="Reporte de Servicios"
             BackgroundColor="#F8F9FA">

	<ScrollView>
		<VerticalStackLayout Padding="25" Spacing="25" VerticalOptions="Start">

			<VerticalStackLayout Spacing="5" Margin="0,10,0,10">
				<Label Text="Consulta de Historial"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="#212121" />
				<Label Text="Seleccione una unidad para generar el resumen de servicios realizados."
                       FontSize="14"
                       TextColor="#757575" />
			</VerticalStackLayout>

			<Border StrokeShape="RoundRectangle 15"
                    StrokeThickness="0"
                    BackgroundColor="White"
                    Padding="20">
				<Border.Shadow>
					<Shadow Brush="Black" Offset="0,2" Opacity="0.05" Radius="10"/>
				</Border.Shadow>

				<VerticalStackLayout Spacing="15">

					<Label Text="UNIDAD REGISTRADA"
                           FontSize="11"
                           FontAttributes="Bold"
                           TextColor="#2196F3"
                           CharacterSpacing="1"/>

					<Border StrokeShape="RoundRectangle 8"
                            Stroke="#E0E0E0"
                            StrokeThickness="1"
                            Padding="10,5">
						<Picker Title="Seleccione un vehículo..."
                                TitleColor="#999999"
                                TextColor="#333333"
                                FontSize="16">
							<Picker.ItemsSource>
								<x:Array Type="{x:Type x:String}">
									<x:String>ABC123 - Nissan Sentra</x:String>
									<x:String>XY2456 - Ford F-150</x:String>
									<x:String>GHI789 - Toyota Corolla</x:String>
								</x:Array>
							</Picker.ItemsSource>
						</Picker>
					</Border>

				</VerticalStackLayout>
			</Border>

			<Button Text="Generar Reporte"
                    HeightRequest="60"
                    BackgroundColor="#2196F3"
                    TextColor="White"
                    FontSize="18"
                    FontAttributes="Bold"
                    CornerRadius="12"
                    Margin="0,10,0,0">
				<Button.Shadow>
					<Shadow Brush="#2196F3" Offset="0,4" Opacity="0.3" Radius="8"/>
				</Button.Shadow>
			</Button>

			<HorizontalStackLayout HorizontalOptions="Center" Spacing="5" Margin="0,20">
				<Label Text="ℹ" TextColor="#2196F3" FontAttributes="Bold" />
				<Label Text="El reporte incluirá costos y fechas."
                       FontSize="12"
                       TextColor="#999999" />
			</HorizontalStackLayout>

		</VerticalStackLayout>
	</ScrollView>

</ContentPage>