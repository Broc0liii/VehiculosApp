<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VehiculosMaui.Views.DetalleVehiculoPage"
             Title="Detalle del Vehículo"
             BackgroundColor="#F8F9FA">

	<ScrollView>
		<VerticalStackLayout Padding="25" Spacing="0">

			<BoxView HeightRequest="2" BackgroundColor="#2196F3" HorizontalOptions="Fill" Margin="0,0,0,20"/>

			<Frame BorderColor="Transparent"
                   CornerRadius="15"
                   Padding="25"
                   HasShadow="True"
                   BackgroundColor="White">

				<VerticalStackLayout Spacing="18">

					<VerticalStackLayout Spacing="2">
						<Label Text="PLACA" FontSize="12" TextColor="#9E9E9E" FontAttributes="Bold" CharacterSpacing="1"/>
						<Label Text="ABC-123" FontSize="26" TextColor="#212121" FontAttributes="Bold" />
					</VerticalStackLayout>

					<BoxView HeightRequest="1" BackgroundColor="#EEEEEE" HorizontalOptions="Fill" />

					<Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, *" RowSpacing="15">

						<VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="2">
							<Label Text="MARCA" FontSize="11" TextColor="#9E9E9E" FontAttributes="Bold"/>
							<Label Text="Nissan" FontSize="17" TextColor="#424242"/>
						</VerticalStackLayout>

						<VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="2">
							<Label Text="MODELO" FontSize="11" TextColor="#9E9E9E" FontAttributes="Bold"/>
							<Label Text="Sentra" FontSize="17" TextColor="#424242"/>
						</VerticalStackLayout>

						<VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="2">
							<Label Text="AÑO" FontSize="11" TextColor="#9E9E9E" FontAttributes="Bold"/>
							<Label Text="2020" FontSize="17" TextColor="#424242"/>
						</VerticalStackLayout>

					</Grid>
				</VerticalStackLayout>
			</Frame>

			<Grid ColumnDefinitions="*, *" ColumnSpacing="12" Margin="0,30,0,0">

				<Button Grid.Column="0"
                        Text="Ver Historial"
                        HeightRequest="55"
                        BackgroundColor="Transparent"
                        TextColor="#6c757d"
                        BorderColor="#6c757d"
                        BorderWidth="1"
                        CornerRadius="10"
                        FontAttributes="Bold" />

				<Button Grid.Column="1"
                        Text="Nuevo Mantto"
                        HeightRequest="55"
                        BackgroundColor="#2196F3"
                        TextColor="White"
                        CornerRadius="10"
                        FontAttributes="Bold">
					<Button.Shadow>
						<Shadow Brush="#2196F3" Offset="0,3" Opacity="0.3" Radius="5"/>
					</Button.Shadow>
				</Button>

			</Grid>

		</VerticalStackLayout>
	</ScrollView>

</ContentPage>